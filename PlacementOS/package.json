{
  "name": "ai-resume-analyzer",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "dev:all": "concurrently -k -n api,web -c blue,green \"npm run api:dev\" \"npm run dev\"",
    "api:dev": "npm run dev --prefix server",
    "api:build": "npm run build --prefix server",
    "api:start": "npm run start --prefix server",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc"
  },
  "dependencies": {
    "@heyputer/puter.js": "^2.2.5",
    "@react-router/node": "7.12.0",
    "@react-router/serve": "7.12.0",
    "@supabase/supabase-js": "^2.100.0",
    "clsx": "^2.1.1",
    "isbot": "^5.1.31",
    "jspdf": "^4.2.1",
    "lightningcss": "^1.31.1",
    "lucide-react": "^0.577.0",
    "pdfjs-dist": "^5.4.530",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-hot-toast": "^2.6.0",
    "react-router": "7.12.0",
    "react-router-dom": "7.12.0",
    "recharts": "^3.8.0",
    "tailwind-merge": "^3.4.0",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@react-router/dev": "7.12.0",
    "@tailwindcss/vite": "^4.1.13",
    "@types/node": "^22.19.7",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.1.2",
    "puppeteer": "^24.40.0",
    "tailwindcss": "^4.1.13",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.7",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
